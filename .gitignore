# Python bytecode and caches
__pycache__/
*.py[codz]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging and build outputs
build/
dist/
site/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Tests and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/
.tox/
.nox/

# Linters and type checkers
.mypy_cache/
.pyright/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Environment variables and local secrets
.env
.env.*
!.env.example

# IDE and editor settings
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~

# Operating-system files
.DS_Store
Thumbs.db
Desktop.ini

# Logs and temporary runtime files
*.log
*.tmp
*.temp
runs/
wandb/

# Raw and preprocessed datasets
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Generated training artifacts
artifacts/tokenizer/*
!artifacts/tokenizer/.gitkeep
artifacts/checkpoints/*
!artifacts/checkpoints/.gitkeep
artifacts/logs/*
!artifacts/logs/.gitkeep
